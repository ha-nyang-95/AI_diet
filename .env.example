# =====================================================
# AI_diet (BalanceNote) — 루트 .env.example
# =====================================================
# 사용법:
#   cp .env.example .env
#   필요한 secret만 채우면 docker compose up 동작
#   (인프라 URL은 docker-compose.yml environment 에 하드코딩 — 시크릿만 .env에서 로딩)
# =====================================================

# --- LLM API keys ---------------------------------------
OPENAI_API_KEY=sk-...                                       # OpenAI gpt-4o — Vision OCR (Story 2.3) + text-embedding-3-small 시드 (Story 3.1) + Self-RAG 광고 가드. 미설정 시 dev/ci/test 시드는 graceful 0건, prod/staging 시드는 비-zero exit.
ANTHROPIC_API_KEY=sk-ant-...                                # Claude — 피드백 생성 듀얼 LLM

# --- LangSmith 옵저버빌리티 ------------------------------
LANGSMITH_API_KEY=ls__...                                   # LangSmith API key (옵션)
LANGSMITH_PROJECT=balancenote-dev                           # LangSmith project 이름
LANGCHAIN_TRACING_V2=true                                   # LangGraph 트레이싱 켬

# --- JWT secrets (사용자 / 관리자 분리) -------------------
JWT_USER_SECRET=replace-with-32-byte-random                 # HS256 - 사용자 JWT
JWT_ADMIN_SECRET=replace-with-different-32-byte-random      # HS256 - 관리자 JWT (별 issuer)
JWT_USER_ISSUER=balancenote-user                            # iss claim
JWT_ADMIN_ISSUER=balancenote-admin                          # iss claim

# --- Sentry 에러 트래킹 ---------------------------------
SENTRY_DSN=                                                 # 빈 값이면 비활성 (dev 권장)

# --- Google OAuth (Story 1.2) ---------------------------
GOOGLE_OAUTH_CLIENT_ID=                                     # Google Cloud Console - OAuth client
GOOGLE_OAUTH_CLIENT_SECRET=                                 #

# --- Cloudflare R2 (이미지 스토리지) ---------------------
R2_ACCOUNT_ID=                                              # CF account id
R2_ACCESS_KEY_ID=                                           # R2 API token
R2_SECRET_ACCESS_KEY=                                       #
R2_BUCKET=balancenote-meals                                 #
R2_PUBLIC_BASE_URL=                                         # https://pub-...r2.dev (또는 CDN)

# --- Expo (모바일 OTA / EAS) -----------------------------
EXPO_ACCESS_TOKEN=                                          # EAS submit / OTA용

# --- 식약처 OpenAPI -------------------------------------
MFDS_OPENAPI_KEY=                                           # 식품영양성분 DB 시드 (Story 3.1 — 공공데이터포털 15127578) — 미설정 시 ZIP fallback(api/data/mfds_food_nutrition_seed.csv) 시도. 둘 다 실패 시 dev/ci/test는 graceful 0건, prod/staging 또는 RUN_FOOD_SEED_STRICT=1 시 비-zero exit. data.go.kr 가입 후 발급 (분당 100회 limit).
# RUN_FOOD_SEED_STRICT=1                                    # dev에서도 prod 동등 fail-fast 강제(opt-in, 테스트 강제 + CI 게이트 옵션).

# --- 결제 (sandbox) -------------------------------------
TOSS_SECRET_KEY=                                            # Toss Payments sandbox (Epic 6)
# STRIPE_SECRET_KEY=                                        # 또는 Stripe (sandbox)

# =====================================================
# 인프라 URL은 docker-compose.yml에서 컨테이너 네트워크로 주입됨
# (DATABASE_URL, REDIS_URL은 여기 작성하지 말 것)
# =====================================================
