# BalanceNote — Production env template (Story 8.5 AC10)
# ============================================================================
# 본 파일은 *템플릿*입니다. 실 값은 *각 dashboard에 직접 주입*하고 git 커밋 금지
# (`.gitignore`에 `.env.production` non-example 등록 완료).
#
# 4 섹션:
#   1) API (bn-api Render Web Service) — `docker/Dockerfile.api` 기반 FastAPI
#   2) Web (bn-web Render Web Service) — `web/` Next.js standalone
#   3) GitHub Actions Secrets — `daily-cost-alert.yml` 등 workflow용
#   4) Sentry console — dashboard에서 수동 발급 후 §1/§2에 주입
#
# 참고:
#   - Render dashboard 환경변수 입력 시 본 파일 항목 1:1 매핑
#   - 상세 SOP는 `docs/runbook/deployment.md` §4.4 참조
#   - JWT_SECRET_KEY는 prod 전용 신규 발급 — `python -c "import secrets; print(secrets.token_urlsafe(32))"`
#   - 시크릿 회전 절차는 `docs/runbook/secret-rotation.md` 참조
# ============================================================================


# === 1. API (bn-api Render Web Service) ====================================
# Supabase Project Settings → Database → Connection string → URI (Transaction
# mode pooler, port 6543, `?pgbouncer=true`). Render Free outbound connection
# 한도 정합 + asyncpg pgbouncer transaction mode 호환.
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true

# `dev`(default) | `staging` | `prod` | `production` | `ci` | `test`. Sentry
# environment tag로 사용 — prod 이슈가 dev/staging과 분리 표시.
ENVIRONMENT=production

# 32+ bytes urlsafe. dev 키 재사용 금지 (dev 사용자 자동 prod 진입 방지).
JWT_SECRET_KEY=

# LLM provider keys — dev 키 재사용 OK (포트폴리오 scope). 인수 시점 분리 발급은
# `secret-rotation.md` §1 참조. Story 8.5에서 Anthropic 제거 — OpenAI 단독 운영.
OPENAI_API_KEY=

# LangSmith — prod project 별 발급 권장(dev trace와 분리).
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=balancenote-prod

# Google OAuth — Web confidential client. dev client_id 재사용 OK,
# `GOOGLE_OAUTH_REDIRECT_URI`는 prod URL로 등록 (Google Console에 추가 완료).
GOOGLE_OAUTH_CLIENT_ID=559604985813-fi8mfivn1fhjgq9a9ehdh5l8qp5iivpk.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bn-web.onrender.com/api/auth/google/callback

# Sentry — backend project DSN (§4 참조).
SENTRY_DSN=

# Storage — `supabase` 분기로 R2 swap (Story 8.5 AC8).
STORAGE_PROVIDER=supabase
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# Supabase Project Settings → API → service_role (NOT anon key). server-side
# 전용 — 클라이언트에 노출 금지.
SUPABASE_SERVICE_KEY=
# Supabase Storage bucket name (Render에서 dashboard 생성 — `meals`, public access OFF,
# file size limit 10 MB).
SUPABASE_STORAGE_BUCKET=meals

# CORS — bn-web origin만 허용 (credentials true 정합 — wildcard 금지).
CORS_ALLOWED_ORIGINS=https://bn-web.onrender.com

# Toss Payments — dev sandbox 키 재사용 OK (포트폴리오 scope, prod live mode는 OUT).
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET_KEY=whsec_...

# Expo push token (모바일 — 선택, 모바일 alert 미사용 시 빈 값).
EXPO_ACCESS_TOKEN=


# === 2. Web (bn-web Render Web Service) ====================================
# Next.js standalone (Story 8.5 AC9 — `output: "standalone"`).
# bn-api URL은 동일 Render org 내 cross-service 호출. Render 자동 HTTPS.
NEXT_PUBLIC_API_BASE_URL=https://bn-api.onrender.com
API_BASE_URL=https://bn-api.onrender.com

# Sentry — frontend project DSN. Web Sentry init wiring은 Story 8.4 polish forward
# (8.5 scope 외). 본 env var는 dashboard 입력 placeholder만 보존.
NEXT_PUBLIC_SENTRY_DSN=

# Google OAuth — bn-api와 동일 값 재사용 (Web client). redirect URI는 bn-web origin.
GOOGLE_OAUTH_CLIENT_ID=559604985813-fi8mfivn1fhjgq9a9ehdh5l8qp5iivpk.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bn-web.onrender.com/api/auth/google/callback

# NODE_ENV는 Render가 production 자동 주입 — 명시 불필요.


# === 3. GitHub Actions Secrets =============================================
# Repository Settings → Secrets and variables → Actions → New repository secret.
# `daily-cost-alert.yml` 호출 — 매일 KST 09:00 cron 실행.

# OpenAI Usage API용 — read-only 별도 발급 권장 (`secret-rotation.md` §1 SOP 정합).
OPENAI_API_KEY=

# LangSmith trace count 조회용 (옵션 — 없으면 LangSmith 단계 skip).
LANGSMITH_API_KEY=

# Discord 채널 webhook URL — Edit Channel → Integrations → Webhooks → New Webhook.
# 비용 알림 채널 전용 권장 (스팸 격리).
DISCORD_COST_WEBHOOK_URL=

# 임계치 (USD) — 어제 합산 cost 비교 기준. 5.0 USD warning, 10.0 USD critical.
THRESHOLD_USD=5.0

# Sentry custom event 발송용 (옵션 — 없으면 Sentry 단계 skip).
SENTRY_AUTH_TOKEN=


# === 4. Sentry 콘솔 (수동 입력) ============================================
# https://sentry.io → Settings → Projects → "+ Create Project".
# 2개 project 분리 발급:
#   - balancenote-api      → SENTRY_DSN              (§1 주입)
#   - balancenote-web      → NEXT_PUBLIC_SENTRY_DSN  (§2 주입, 8.4 forward)
# 각 project Settings → Client Keys (DSN) → 발급된 DSN을 위 env에 붙여넣기.
