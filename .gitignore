# =====================================================
# AI_diet (BalanceNote) — root .gitignore
# =====================================================

# --- Environments / Secrets -----------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.pem
*.key
secrets/

# --- Python (api/) --------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.python-version
!api/.python-version  # api 폴더 pinned 버전은 커밋 (uv-pinned per repo)
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# --- Node / TS (web, mobile) ----------------------------
node_modules/
.pnpm-store/
.next/
.turbo/
.expo/
.expo-shared/
.vercel/
.cache/
dist/
out/
build/
coverage/
*.tsbuildinfo
.eslintcache

# --- Lockfile policy ------------------------------------
# pnpm-lock.yaml is COMMITTED (intentional, do not ignore)
package-lock.json   # ts side standardizes on pnpm, lock conflicts forbidden
yarn.lock

# --- OpenAPI generated artifacts ------------------------
# Generated clients are committed — do not ignore — to enable openapi-diff CI gate
# web/src/lib/api-client.ts  (committed)
# mobile/lib/api-client.ts   (committed)

# --- IDE / Editor ---------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo
.history/

# --- OS -------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Claude Code / BMad personal overrides --------------
.claude/settings.local.json
_bmad/config.user.toml
_bmad/custom/*.user.toml

# --- Logs / temp ----------------------------------------
*.log
logs/
*.tmp
*.bak
.tmp/

# --- Docker (build artifacts only — yml/Dockerfile committed)
*.tar
*.tar.gz

# Note: _bmad-output/ is INTENTIONALLY tracked (BMad planning artifacts).
# Do NOT add it here.
