# Mobile (Expo) 환경변수
# 사용법: cp .env.example .env

# 백엔드 API base URL — Expo는 EXPO_PUBLIC_* 변수만 클라이언트 번들에 포함
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth client ids (Story 1.2)
# Expo Go 개발 중에는 Web client id를 사용해 PKCE 흐름 검증.
# EAS native build 산출물(iOS/Android)은 각 플랫폼 client id 사용.
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID_WEB=

# Expo push notifications (Story 4.1) — EAS projectId placeholder.
# EAS Build 시 자동 주입. 로컬 dev에서는 `app.config.ts:expo.extra.eas.projectId`가 SOT —
# 본 env는 fallback. EAS Console > Project Settings > Project ID 위치 (`docs/runbook/push-notifications-dev.md` §2 참조).
EXPO_PUBLIC_EAS_PROJECT_ID=
