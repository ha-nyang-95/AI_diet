# Web (Next.js) 환경변수
# 사용법: cp .env.example .env.local

# 백엔드 API base URL — server-only (route handler에서만 사용).
# 브라우저는 백엔드를 직접 호출하지 않고, Next.js route handler를 경유한다.
API_BASE_URL=http://localhost:8000

# 클라이언트 노출용 (NEXT_PUBLIC_* prefix만 브라우저 번들에 포함)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth (Story 1.2)
# server-only — route handler가 token exchange에 사용. 클라이언트 브라우저 노출 금지.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Toss Payments (Story 6.1) — Toss 공식 client key.
# sandbox 키: ``test_ck_<...>`` 형태 — Toss 개발자 콘솔에서 발급.
# prod 키: ``live_ck_<...>`` — 외주 인수 클라이언트가 자체 등록 (epics.md:855 SOP).
# NEXT_PUBLIC_* prefix — 클라이언트 번들 노출(Toss widget이 브라우저에서 SDK init).
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_DnyRpQWGrN0BKAoJ4BwM8Kwv1M9E
